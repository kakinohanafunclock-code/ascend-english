# --- Claude API (AI 添削・解説・カリキュラム生成) ---
# 安価なモデルを既定にしてコストを抑える。
VITE_CLAUDE_MODEL=claude-haiku-4-5-20251001

# AI 呼び出しの方式:
#   "proxy" (推奨/既定) … 自前のサーバ関数経由でキーを秘匿（本番）
#   "direct"           … ブラウザから直接呼ぶ（ローカル検証のみ。キーが露出するため本番禁止）
VITE_AI_MODE=proxy

# proxy モード時のエンドポイント（Vercel/Netlify Functions など）
VITE_AI_PROXY_URL=/api/ai

# direct モード時のみ使用（本番では絶対に設定しない。.env はコミットしない）
# VITE_CLAUDE_API_KEY=sk-ant-...

# サーバ側（proxy 関数 /api/ai）で参照するキー。フロントには露出しない。
# CLAUDE_API_KEY=sk-ant-...

# --- Web Push (任意。未設定ならローカル通知のみで動作) ---
# 鍵の生成: npx web-push generate-vapid-keys
# VITE_VAPID_PUBLIC_KEY=
# VAPID_PUBLIC_KEY=          # サーバ(api/push/send)用。VITE_ と同じ公開鍵。
# VAPID_PRIVATE_KEY=         # サーバのみ。絶対にコミットしない。

# --- Supabase クラウド同期（任意。未設定ならローカルのみで動作） ---
# フロント（同期 + 端末状態の保存）。URL はプロジェクトURLのみ（/rest/v1/ は付けない）。
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=
# サーバ（push購読の保存・配信。service role キーはサーバのみ・絶対にコミットしない）
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
